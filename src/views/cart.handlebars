<h1>Carrito</h1>

{{#each products}}
<div class="product-card">
    <h3>{{this.product.title}}</h3>
    <p>Precio: ${{this.product.price}}</p>
    <p>Cantidad: {{this.quantity}}</p>
</div>
{{/each}}

{{#unless products.length}}
<p>El carrito esta vacio</p>
{{/unless}}

<a href="/products" class="btn">⬅ Seguir comprando</a>