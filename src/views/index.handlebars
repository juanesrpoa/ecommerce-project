<h1>Productos disponibles</h1>

{{#each products}}
<div class="product-card">
    <h3>{{this.title}}</h3>
    <p>Precio: ${{this.price}}</p>
    <p>Categoria: {{this.category}}</p>
    <a href="/products/{{this._id}}" class="btn">Ver detalle</a>
</div>
{{/each}}

<div class="pagination">
    <p>Pagina {{page}} de {{totalPages}}</p>
    {{#if hasPrevPage}}
    <a href="/products?page={{prevPage}}">⬅ Anterior</a>
    {{/if}}
    {{#if hasNextPage}}
    <a href="/products?page={{nextPage}}">Siguiente ➡</a>
    {{/if}}
</div>